# 🐘 EREVNA BACKEND ENVIRONMENT VARIABLES
# Fill in your actual values here, then rename to .env

# Database Configuration - GET FROM NEON.TECH
NEON_DATABASE_URL=postgresql://your_username:your_password@ep-xxx-xxx.us-east-1.aws.neon.tech/erevna?sslmode=require&channel_binding=require

# Flask Configuration
FLASK_ENV=production
HOST=0.0.0.0

# JWT Configuration (Render will auto-generate)
# JWT_SECRET_KEY=auto_generated_by_render

# Email Configuration - GMAIL SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com
